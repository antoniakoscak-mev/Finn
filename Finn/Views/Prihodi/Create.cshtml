@model Finn.Models.Prihod

<div class="d-flex justify-content-between align-items-center mb-5">

    <div>

        <h1 class="fw-bold display-6 mb-1">
            Novi prihod
        </h1>

        <p class="text-muted mb-0">
            Dodavanje novog prihoda u financijski pregled
        </p>

    </div>

    <a asp-action="Index"
       class="btn rounded-pill px-4 py-2"
       style="
            background-color:white;
            color:black;
            border:1px solid #cbd5e1;
            font-weight:600;
       ">

        Povratak

    </a>

</div>

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body p-4 p-lg-5">

        <form asp-action="Create">

            <div class="row g-4">

              

                <div class="col-md-6">

                    <label class="form-label fw-semibold mb-2">
                        Iznos prihoda
                    </label>

                    <input asp-for="Iznos"
                           class="form-control form-control-lg rounded-3" />

                    <span asp-validation-for="Iznos"
                          class="text-danger small">
                    </span>

                </div>

              

                <div class="col-md-6">

                    <label class="form-label fw-semibold mb-2">
                        Kategorija prihoda
                    </label>

                    <select asp-for="Kategorija"
                            class="form-select form-select-lg rounded-3">

                        <option value="">
                            Odaberi kategoriju
                        </option>

                        @foreach (string kategorija in ViewBag.Kategorije)
                        {
                            <option value="@kategorija">

                                @kategorija

                            </option>
                        }

                    </select>

                </div>


                <div class="col-md-6">

                    <label class="form-label fw-semibold mb-2">
                        Datum prihoda
                    </label>

                    <input asp-for="Datum"
                           type="date"
                           class="form-control form-control-lg rounded-3" />

                    <span asp-validation-for="Datum"
                          class="text-danger small">
                    </span>

                </div>

                <div class="col-md-6">

                    <label class="form-label fw-semibold mb-2">
                        Vrsta prihoda
                    </label>

                    <select asp-for="TipPrihoda"
                            class="form-select form-select-lg rounded-3">

                        <option value="Predviđeni">
                            Predviđeni
                        </option>

                        <option value="Nepredviđeni">
                            Nepredviđeni
                        </option>

                    </select>

                    <span asp-validation-for="TipPrihoda"
                          class="text-danger small">
                    </span>

                </div>

                <div class="col-12">

                    <label class="form-label fw-semibold mb-2">
                        Opis prihoda
                    </label>

                    <textarea asp-for="Opis"
                              rows="5"
                              class="form-control rounded-3">
                    </textarea>

                    <span asp-validation-for="Opis"
                          class="text-danger small">
                    </span>

                </div>

            </div>

           

            <div class="d-flex gap-3 mt-5">

                <button type="submit"
                        class="btn text-white px-4 py-2 rounded-pill shadow-sm"
                        style="
                            background: linear-gradient(135deg, #2563eb, #1d4ed8);
                            border:none;
                            font-weight:600;
                        ">

                    Spremi prihod

                </button>

                <a asp-action="Index"
                   class="btn rounded-pill px-4 py-2"
                   style="
                        background-color:white;
                        color:black;
                        border:1px solid #cbd5e1;
                        font-weight:600;
                   ">

                    Odustani

                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}