@using System.Text.Json

<style>

  
    .dashboard-card {
        transition: all .25s ease;
    }

        .dashboard-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 50px rgba(0,0,0,.12);
        }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>

        <h2 class="fw-bold mb-1">
            Dashboard
        </h2>

    </div>

    <a asp-action="Pdf"
       asp-route-period="@Context.Request.Query["period"]"
       asp-route-kategorija="@Context.Request.Query["kategorija"]"
       asp-route-datumOd="@Context.Request.Query["datumOd"]"
       asp-route-datumDo="@Context.Request.Query["datumDo"]"
       class="btn btn-dark rounded-pill px-4">

        Financijsko izvješće PDF

    </a>

</div>

<!-- SAŽETAK -->

<div class="row g-4 mb-4">

    <div class="col-md-4">

        <div class="card dashboard-card border-0 shadow-sm rounded-4 text-white h-100"
             style="background: linear-gradient(
                135deg,
                #065f46 0%,
                #0f766e 50%,
                #5eead4 100%);">

            <div class="card-body p-4">

                <p class="small text-uppercase opacity-75 mb-2">
                    📈 Prihodi
                </p>

                <h2 class="fw-bold mb-0">
                    @ViewBag.UkupniPrihodi.ToString("N2") €
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card dashboard-card border-0 shadow-sm rounded-4 text-white h-100"
             style="background: linear-gradient(
                135deg,
                #1e40af 0%,
                #2563eb 50%,
                #93c5fd 100%);">

            <div class="card-body p-4">

                <p class="small text-uppercase opacity-75 mb-2">
                    📉  Rashodi
                </p>

                <h2 class="fw-bold mb-0">
                    @ViewBag.UkupniRashodi.ToString("N2") €
                </h2>

            </div>

        </div>

    </div>

    <div class="col-md-4">

        <div class="card dashboard-card border-0 shadow-sm rounded-4 text-white h-100"
             style="background: linear-gradient(
                135deg,
                #6d28d9 0%,
                #8b5cf6 50%,
                #c4b5fd 100%);">

            <div class="card-body p-4">

                <p class="small text-uppercase opacity-75 mb-2">
                    💰 Stanje
                </p>

                <h2 class="fw-bold mb-0">
                    @ViewBag.Stanje.ToString("N2") €
                </h2>

            </div>

        </div>

    </div>

</div>


<!-- FILTERI -->

<div class="card border-0 shadow-sm rounded-4 mb-4">

    <div class="card-body p-3">

        <form method="get">

            <div class="d-flex flex-wrap gap-2 align-items-center mb-3">

                <button type="submit"
                        name="period"
                        value=""
                        onclick="
                            document.getElementsByName('datumOd')[0].value='';
                            document.getElementsByName('datumDo')[0].value='';
                        "
                        class="btn rounded-pill px-3 py-2 @(string.IsNullOrEmpty(ViewBag.AktivniPeriod) && ViewBag.DatumOd == null && ViewBag.DatumDo == null ? "btn-dark text-white" : "btn-light border")">

                    Svi periodi

                </button>

                <button type="submit"
                        name="period"
                        value="ThisMonth"
                        onclick="
                            document.getElementsByName('datumOd')[0].value='';
                            document.getElementsByName('datumDo')[0].value='';
                        "
                        class="btn rounded-pill px-3 py-2 @(ViewBag.AktivniPeriod == "ThisMonth" ? "btn-dark text-white" : "btn-light border")">

                    Ovaj mjesec

                </button>

                <button type="submit"
                        name="period"
                        value="LastMonth"
                        onclick="
                            document.getElementsByName('datumOd')[0].value='';
                            document.getElementsByName('datumDo')[0].value='';
                        "
                        class="btn rounded-pill px-3 py-2 @(ViewBag.AktivniPeriod == "LastMonth" ? "btn-dark text-white" : "btn-light border")">

                    Prošli mjesec

                </button>

                <button type="submit"
                        name="period"
                        value="ThisYear"
                        onclick="
                            document.getElementsByName('datumOd')[0].value='';
                            document.getElementsByName('datumDo')[0].value='';
                        "
                        class="btn rounded-pill px-3 py-2 @(ViewBag.AktivniPeriod == "ThisYear" ? "btn-dark text-white" : "btn-light border")">

                    Ova godina

                </button>

                <button type="submit"
                        name="period"
                        value="LastYear"
                        onclick="
                            document.getElementsByName('datumOd')[0].value='';
                            document.getElementsByName('datumDo')[0].value='';
                        "
                        class="btn rounded-pill px-3 py-2 @(ViewBag.AktivniPeriod == "LastYear" ? "btn-dark text-white" : "btn-light border")">

                    Prošla godina

                </button>

            </div>

            <div class="row g-2 align-items-end">

                <div class="col-md-3">

                    <label class="form-label small fw-semibold mb-1">
                        Datum od
                    </label>

                    <input type="date"
                           name="datumOd"
                           value="@ViewBag.DatumOd"
                           class="form-control rounded-3 @(ViewBag.DatumOd != null ? "border-dark border-2" : "")" />

                </div>

                <div class="col-md-3">

                    <label class="form-label small fw-semibold mb-1">
                        Datum do
                    </label>

                    <input type="date"
                           name="datumDo"
                           value="@ViewBag.DatumDo"
                           class="form-control rounded-3 @(ViewBag.DatumDo != null ? "border-dark border-2" : "")" />

                </div>

                <div class="col-md-3">

                    <label class="form-label small fw-semibold mb-1">
                        Kategorija
                    </label>

                    <select name="kategorija"
                            class="form-select rounded-3 @(ViewBag.AktivnaKategorija != null ? "border-dark border-2" : "")">

                        <option value="">
                            Sve kategorije
                        </option>

                        @foreach (var kategorija in ViewBag.Kategorije)
                        {
                            if (ViewBag.AktivnaKategorija == kategorija)
                            {
                                <option value="@kategorija" selected>

                                    @kategorija

                                </option>
                            }
                            else
                            {
                                <option value="@kategorija">

                                    @kategorija

                                </option>
                            }
                        }

                    </select>

                </div>

                <div class="col-md-3">

                    <button type="submit"
                            class="btn btn-dark rounded-pill w-100">

                        Filtriraj

                    </button>

                </div>

            </div>

        </form>

    </div>

</div>

@if (!string.IsNullOrEmpty(ViewBag.FilterPoruka))
{
    <div class="mb-4">

        <span style="
                font-size:13px;
                color:#64748b;
                font-weight:400;
                      ">

            Prikazani podaci:
            @ViewBag.FilterPoruka

        </span>

    </div>
}




<!-- KATEGORIJE -->

<div class="mb-3">

    <!-- RASHODI -->

    <div class="mb-2">

        <p class="text-muted small mb-0">

            Pregled potrošnje po kategorijama

        </p>

    </div>

    <div class="d-flex flex-wrap gap-2 mb-3">

        @foreach (var kartica in ViewBag.RashodKartice)
        {
            <div class="card border-0 shadow-sm rounded-4"
                 style="
                    min-width:140px;
                    max-width:165px;
                    flex:1;
                     ">

                <div class="card-body p-2">

                    <div class="d-flex align-items-center gap-2">

                        <div style="
                                width:34px;
                                height:34px;
                                border-radius:12px;
                                background:@kartica.Boja20;
                                display:flex;
                                align-items:center;
                                justify-content:center;
                                font-size:16px;
                                 ">

                            @kartica.Ikona

                        </div>

                        <div>

                            <div class="text-muted"
                                 style="
                                    font-size:12px;
                                    line-height:1.1;
                                     ">

                                @kartica.Naziv

                            </div>

                            <div class="fw-bold"
                                 style="
                                    font-size:15px;
                                    line-height:1.1;
                                     ">

                                @kartica.Iznos.ToString("N2") €

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

    <!-- PRIHODI -->

    <div class="mb-2">

        <p class="text-muted small mb-0">

            Pregled prihoda po kategorijama

        </p>

    </div>

    <div class="d-flex flex-wrap gap-2">

        @foreach (var kartica in ViewBag.PrihodKartice)
        {
            <div class="card border-0 shadow-sm rounded-4"
                 style="
                    min-width:140px;
                    max-width:165px;
                    flex:1;
                     ">

                <div class="card-body p-2">

                    <div class="d-flex align-items-center gap-2">

                        <div style="
                                width:34px;
                                height:34px;
                                border-radius:12px;
                                background:@kartica.Boja20;
                                display:flex;
                                align-items:center;
                                justify-content:center;
                                font-size:16px;
                                 ">

                            @kartica.Ikona

                        </div>

                        <div>

                            <div class="text-muted"
                                 style="
                                    font-size:12px;
                                    line-height:1.1;
                                     ">

                                @kartica.Naziv

                            </div>

                            <div class="fw-bold"
                                 style="
                                    font-size:15px;
                                    line-height:1.1;
                                     ">

                                @kartica.Iznos.ToString("N2") €

                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>




<!-- ZADNJE TRANSAKCIJE -->

<div class="row g-4">

    <div class="col-lg-6">

        <div class="card border-0 shadow-sm rounded-4 h-100">

            <div class="card-body p-4">

                <h5 class="fw-bold mb-4">
                    Zadnji prihodi
                </h5>

                <div class="d-flex flex-column gap-3">

                    @foreach (var prihod in ViewBag.Prihodi)
                    {
                        <div class="d-flex justify-content-between align-items-center border rounded-4 p-3">

                            <div>

                                <div class="fw-semibold">
                                    @prihod.Kategorija
                                </div>

                                <small class="text-muted">
                                    @prihod.Datum.ToString("dd/MM/yyyy")
                                </small>

                            </div>

                            <div class="fw-bold text-primary">
                                +@prihod.Iznos.ToString("N2") €
                            </div>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-6">

        <div class="card border-0 shadow-sm rounded-4 h-100">

            <div class="card-body p-4">

                <h5 class="fw-bold mb-4">
                    Zadnji rashodi
                </h5>

                <div class="d-flex flex-column gap-3">

                    @foreach (var rashod in ViewBag.Troskovi)
                    {
                        <div class="d-flex justify-content-between align-items-center border rounded-4 p-3">

                            <div>

                                <div class="fw-semibold">
                                    @rashod.Kategorija
                                </div>

                                <small class="text-muted">
                                    @rashod.Datum.ToString("dd/MM/yyyy")
                                </small>

                            </div>

                            <div class="fw-bold text-dark">
                                -@rashod.Iznos.ToString("N2") €
                            </div>

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>