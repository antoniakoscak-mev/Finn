@{
}
@model Finn.Models.Trosak

<div class="card border-0 shadow-sm rounded-4">

    <div class="card-body p-4">

        <h3 class="fw-bold mb-4">
            Uredi rashod
        </h3>

        <form asp-action="Edit">

            <input type="hidden"
                   asp-for="Id" />

            <div class="mb-3">

                <label class="form-label">
                    Iznos
                </label>

                <input asp-for="Iznos"
                       class="form-control rounded-3" />

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Kategorija
                </label>

                <select asp-for="Kategorija"
                        class="form-select rounded-3">

                    @foreach (string kategorija in ViewBag.Kategorije)
                    {
                        <option value="@kategorija">

                            @kategorija

                        </option>
                    }

                </select>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Datum
                </label>

                <input asp-for="Datum"
                       type="date"
                       class="form-control rounded-3" />

            </div>

            <div class="mb-4">

                <label class="form-label">
                    Opis
                </label>

                <textarea asp-for="Opis"
                          class="form-control rounded-3">
                </textarea>

            </div>

            <button class="btn btn-dark rounded-pill px-4">

                Spremi

            </button>

        </form>

    </div>

</div>