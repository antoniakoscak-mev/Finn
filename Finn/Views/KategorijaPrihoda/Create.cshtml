@model Finn.Models.KategorijaPrihoda

<h1 class="fw-bold mb-5">
    Nova kategorija prihoda
</h1>

<form asp-action="Create">

    <div class="mb-4">

        <label class="form-label">
            Naziv kategorije
        </label>

        <input asp-for="Naziv"
               class="form-control" />

    </div>

    <div class="mb-4">

        <label class="form-label">
            Boja kategorije
        </label>

        <input asp-for="Boja"
               type="color"
               class="form-control form-control-color" />

    </div>

    <button type="submit"
            class="btn btn-primary">

        Spremi

    </button>

</form>