@using Finn.Data
@using Finn.Models
@using System.Security.Claims
@inject ApplicationDbContext ContextDb

<!DOCTYPE html>
<html lang="hr">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>Finn</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>

        body {
            margin: 0;
            background-color: #f6f8fb;
            font-family: 'Segoe UI';
            color: #111827;
        }

        .sidebar {
            width: 260px;
            height: 100vh;
            background-color: white;
            position: fixed;
            left: 0;
            top: 0;
            border-right: 1px solid #e5e7eb;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            padding: 28px 20px;
        }

        .logo {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 45px;
            letter-spacing: -1px;
        }

        .nav-section {
            display: flex;
            flex-direction: column;
        }

        .nav-link-custom {
            text-decoration: none;
            color: #374151;
            font-weight: 500;
            padding: 14px 18px;
            border-radius: 14px;
            margin-bottom: 8px;
            transition: 0.2s;
            font-size: 15px;
        }

            .nav-link-custom:hover {
                background-color: #f3f4f6;
                color: #111827;
            }

        .bottom-section {
            border-top: 1px solid #f1f5f9;
            padding-top: 18px;
        }

        .user-box {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 18px;
            padding: 0 4px;
        }

        .user-avatar {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            background-color: #111827;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 600;
        }

        .user-name {
            font-size: 14px;
            font-weight: 600;
            color: #111827;
        }

        .user-subtitle {
            font-size: 12px;
            color: #9ca3af;
        }

        .logout-link {
            text-decoration: none;
            color: #9ca3af;
            font-size: 13px;
            padding: 10px 14px;
            border-radius: 12px;
            transition: 0.2s;
            display: inline-block;
        }

            .logout-link:hover {
                background-color: #f3f4f6;
                color: #111827;
            }

        .main-content {
            padding: 35px;
        }

        .with-sidebar {
            margin-left: 260px;
        }

    </style>

</head>

<body>

    @{
        var isAuthPage =
        Context.Request.Path
        .ToString()
        .Contains("/Auth/Login")
        ||
        Context.Request.Path
        .ToString()
        .Contains("/Auth/Register");
    }

    @if (User.Identity.IsAuthenticated && !isAuthPage)
    {
        <div class="sidebar">

            <div>

                <div class="logo">
                    Finn
                </div>

                <div class="nav-section">

                    <a class="nav-link-custom"
                       asp-controller="Home"
                       asp-action="Index">

                        Dashboard

                    </a>

                    <a class="nav-link-custom"
                       asp-controller="Prihodi"
                       asp-action="Index">

                        Prihodi

                    </a>

                    <a class="nav-link-custom"
                       asp-controller="Troskovi"
                       asp-action="Index">

                        Rashodi

                    </a>

                    <a class="nav-link-custom"
                       asp-controller="Budzet"
                       asp-action="Index">

                        Budžet

                    </a>

                    <a class="nav-link-custom"
                       asp-controller="Analitika"
                       asp-action="Index">

                        Analitika

                    </a>

                </div>

            </div>

            <div class="bottom-section">

                <div class="user-box">

                    <div class="user-avatar">

                        @(User.Identity.Name.Substring(0, 1).ToUpper())

                    </div>

                    <div>

                        <div class="user-name">

                            @User.Identity.Name

                        </div>

                        @{
                            var userId =
                            User.FindFirstValue(
                            ClaimTypes.NameIdentifier);

                            var settings =
                            ContextDb.UserSettings
                            .FirstOrDefault(x =>
                            x.UserId == userId);
                        }

                        <div class="user-subtitle">

                            @if (settings?.TipRacuna == "Poslovni")
                            {
                                <text>🏢 Poslovni račun</text>
                            }
                            else
                            {
                                <text>👤 Osobni račun</text>
                            }

                        </div>

                    </div>

                </div>

                <a asp-controller="Auth"
                   asp-action="Logout"
                   class="logout-link">

                    Odjavi se

                </a>

            </div>

        </div>

        <div class="main-content with-sidebar">

            @RenderBody()

        </div>
    }
    else
    {
        <div class="main-content">

            @if (!User.Identity.IsAuthenticated)
            {
                <div class="d-flex justify-content-end mb-4 gap-2">

                    <a asp-controller="Auth"
                       asp-action="Login"
                       class="btn btn-dark rounded-pill px-4">

                        Prijava

                    </a>

                    <a asp-controller="Auth"
                       asp-action="Register"
                       class="btn btn-light border rounded-pill px-4">

                        Registracija

                    </a>

                </div>
            }

            @RenderBody()

        </div>
    }

    @await RenderSectionAsync(
            "Scripts",
            required: false)

</body>

</html>